# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings → API in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Project Settings → API → service_role key. NEVER expose this to the
# browser (no NEXT_PUBLIC_ prefix) — it bypasses Row Level Security and is
# only read by the SePay webhook route on the server. See SEPAY_SETUP.md.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SePay (sepay.vn) — bank-transfer checkout. See SEPAY_SETUP.md.
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-secret
SEPAY_BANK_ACCOUNT_NUMBER=0123456789
SEPAY_BANK_NAME=MBBank
SEPAY_BANK_ACCOUNT_HOLDER=NGUYEN VAN A
